rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Super admins collection — authenticated users can read; writes allowed for seeding
    match /superAdmins/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Users collection — authenticated users can read their own doc; admins can read/write all
    match /users/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Organizations — authenticated users can read; creation requires auth
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Org subcollections (surveys, staff, settings) — authenticated users can read/write
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Mail collection — used by Trigger Email extension (Resend)
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Extension-only
    }

    // Legacy allowedUsers collection (keeping for backward compat during migration)
    match /allowedUsers/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
